# App Configurations
APP_ENV=development
DEBUG=True
DATABASE_URL=sqlite:///./phishing_platform.db

# API Security Keys
# VirusTotal API key (Get from https://www.virustotal.com/)
VIRUSTOTAL_API_KEY=your_virustotal_api_key_here

# Google Gemini API key (Get from https://aistudio.google.com/)
GEMINI_API_KEY=your_gemini_api_key_here

# IMAP Email Source Credentials (to fetch live suspicious emails)
# Set up a dedicated test email inbox with App Passwords enabled
IMAP_SERVER=imap.gmail.com
IMAP_PORT=993
IMAP_EMAIL=test_analyst@gmail.com
IMAP_PASSWORD=your_app_specific_password_here
IMAP_FOLDER=INBOX
